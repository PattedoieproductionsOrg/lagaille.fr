import BaseLayout from "@layout/BaseLayout.astro";
import { getFaq } from "@utils/faq-api";
import type { WithContext, FAQPage } from "schema-dts";

let faqData =3D null;
let error =3D null;

try {
  faqData =3D await getFaq();
} catch (e) {
  error =3D e.message;
  console.error("Erreur:", e);
}

const seo =3D {
  title: "FAQ - Questions Fr=C3=A9quentes",
  description: "Trouvez les r=C3=A9ponses =C3=A0 vos questions.",
};

// Schema.org pour le SEO
const schemaQuestions =3D [];
if (faqData) {
  faqData.categories.forEach((category) =3D&gt; {
    category.questions.forEach((q) =3D&gt; {
      schemaQuestions.push({
        "@type": "Question",
        name: q.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: q.responsePublic || q.response,
        },
      });
    });
  });
}

const schema: WithContext&lt;FAQPage&gt; =3D {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: schemaQuestions,
};
