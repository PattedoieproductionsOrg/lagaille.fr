<section class="hero">
	<div class="container">
		<div class="hero-content">
            <div class="logo-wrapper">
                <img src="/pattedoie_logo_jaune.png" alt="Pattedoie Productions" class="logo" />
            </div>
			<p class="mission">
				Notre mission : propulser la nouvelle génération du stand-up français.
				Nous dénichons, accompagnons et produisons les talents qui feront rire la France de demain.
			</p>
		</div>
	</div>
</section>

<style>
	.hero {
		padding: 6rem 0 4rem;
		min-height: 60vh;
		display: flex;
		align-items: center;
		background: radial-gradient(circle at top right, rgba(255, 69, 0, 0.1), transparent 40%);
	}
	
    .logo-wrapper {
        margin-bottom: 2rem;
        max-width: 800px;
    }
    
    .logo {
        width: 100%;
        height: auto;
    }
	
	.text-gradient {
		background: linear-gradient(45deg, var(--color-accent), var(--color-accent-2));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	
	.mission {
		font-size: 1.25rem;
		max-width: 600px;
		font-weight: 300;
	}
</style>
