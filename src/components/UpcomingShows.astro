---
const shows = [
	{
		title: "La Nuit du Rire",
		date: "15 Octobre 2025",
		location: "Le Paname Art Café, Paris",
		description: "Un plateau d'exception réunissant 5 de nos meilleurs artistes."
	},
	{
		title: "Stand-up Factory",
		date: "22 Octobre 2025",
		location: "La Scène Barbès, Paris",
		description: "Découvrez les pépites de demain avant tout le monde."
	},
	{
		title: "Pattedoie Comedy Club",
		date: "5 Novembre 2025",
		location: "Théâtre de Dix Heures, Paris",
		description: "Notre résidence mensuelle avec une programmation surprise."
	}
];
---

<section class="shows container">
	<h2>Prochaines Dates</h2>
	<div class="shows-grid">
		{shows.map(show => (
			<article class="show-card">
				<div class="date-badge">{show.date}</div>
				<h3>{show.title}</h3>
				<p class="location">{show.location}</p>
				<p class="description">{show.description}</p>
				<a href="#" class="btn-ticket">Réserver</a>
			</article>
		))}
	</div>
</section>

<style>
	.shows {
		padding: 4rem 1.5rem;
	}
	
	h2 {
		font-size: 3rem;
		margin-bottom: 3rem;
	}
	
	.shows-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}
	
	.show-card {
		background: var(--color-card-bg);
		padding: 2rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		transition: transform 0.2s, border-color 0.2s;
	}
	
	.show-card:hover {
		transform: translateY(-5px);
		border-color: var(--color-accent);
	}
	
	.date-badge {
		color: var(--color-accent);
		font-weight: 600;
		text-transform: uppercase;
		font-size: 0.9rem;
		margin-bottom: 0.5rem;
	}
	
	h3 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}
	
	.location {
		color: var(--color-text-muted);
		font-style: italic;
		margin-bottom: 1rem;
	}
	
	.btn-ticket {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 0.5rem 1.5rem;
		background: white;
		color: black;
		font-weight: 600;
		border-radius: 2rem;
		transition: background 0.2s;
	}
	
	.btn-ticket:hover {
		background: var(--color-accent);
	}
</style>
