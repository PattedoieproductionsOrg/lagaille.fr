marked.setOptions({ breaks: true, gfm: true });

const { slug } =3D Astro.params;
if (!slug) return Astro.redirect("/blog");

let article =3D null;
let htmlContent =3D "";

try {
  article =3D await getArticle(slug);
  let content =3D article.contentPublic || article.content || "";

  // Retirer le titre H1 du d=C3=A9but s'il est pr=C3=A9sent
  const h1Regex =3D /^#\s+(.+?)(\r?\n|$)/;
  const match =3D content.match(h1Regex);
  if (match &amp;&amp; match[1].trim() =3D=3D=3D article.title.trim()) {
    content =3D content.replace(h1Regex, "").trim();
  }

  htmlContent =3D marked.parse(content);
} catch (e) {
  return Astro.redirect("/blog");
}

const readingTime =3D calculateReadingTime(article.content || "");

